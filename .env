# =============================================================================
# Netlify — fill values, then import (CLI: netlify env:import .env)
# Or: Netlify UI → Environment variables → Import from .env file
#
# TURNSTILE_SITE_KEY must be available at BUILD time (not functions-only).
# Other keys: Functions scope or "All" is fine.
#
# If you paste real secrets into this file, do not commit it. Use .env.local
# for secrets-only overrides (gitignored), or import then strip values from git.
# =============================================================================

# --- Build: Turnstile public site key (contact form + checkout confirm) ---
TURNSTILE_SITE_KEY=
# --- Build: Google Search Console (HTML tag content only) — optional ---
GOOGLE_SITE_VERIFICATION=

# --- Functions: Authorize.Net ---
ANET_PUBLIC_CLIENT_KEY=
ANET_API_LOGIN_ID=
ANET_TRANSACTION_KEY=
# false = production api/js hosts; true = sandbox apitest/jstest
ANET_SANDBOX=false

# --- Functions: Resend (order confirmation email) ---
RESEND_API_KEY=
RESEND_FROM=
# RESEND_SALES_EMAIL=sales@rettmarkfirearms.com
# RESEND_REPLY_TO=
# RESEND_DEBUG=

# --- Functions: Private GitHub discount rules JSON ---
GITHUB_DISCOUNT_TOKEN=
GITHUB_DISCOUNT_OWNER=
GITHUB_DISCOUNT_REPO=
GITHUB_DISCOUNT_PATH=discount-codes.json
GITHUB_DISCOUNT_REF=main

# --- Functions: Checkout hardening (see docs/security-checkout.md) ---
# Comma-separated exact origins (no trailing slashes). Required for strict CORS in production.
CHECKOUT_ALLOWED_ORIGINS=https://rettmarkfirearms.com,https://www.rettmarkfirearms.com
# Cloudflare Turnstile secret (pairs with TURNSTILE_SITE_KEY); required for charges when set
TURNSTILE_SECRET_KEY=
# 1 = fail charges if secret missing (recommended production)
REQUIRE_TURNSTILE_ON_CHARGE=1
# 1 = expose /.netlify/functions/anet-verify-keys (leave unset in production)
# ANET_VERIFY_KEYS_ENABLED=

# --- Optional: alternate names (only if you do not use ANET_* above) ---
# AUTHORIZE_NET_CLIENT_KEY=
# AUTHORIZE_NET_API_LOGIN=
# AUTHORIZE_NET_TRANSACTION_KEY=
# RETTMARK_TURNSTILE_SITE_KEY=
